# Subscription source URL (required). Example: https://example.com/subscription
RAW_SUB_URL=""

# Host port exposed for proxy clients on your machine.
# Mapping: host ALL_PROXY_PORT <-> container MIXED_PORT
ALL_PROXY_PORT=17890

# Host port exposed for dashboard web UI.
# Mapping: host CONTROL_PANEL_PORT <-> container DASHBOARD_PORT
CONTROL_PANEL_PORT=19091

# Container mixed proxy port used by mihomo core.
MIXED_PORT=7890

# External controller API port.
EXTERNAL_CONTROLLER_PORT=19090

# Container dashboard port served by nginx.
DASHBOARD_PORT=80

# API auth secret for external-controller.
SECRET="change-me"

# Host port exposed for subconverter service.
SUBCONVERTER_HOST_PORT=25501

# Subconverter output target. Recommended: clash
SUBCONVERTER_TARGET=clash

# Optional subconverter template.
SUBCONVERTER_TEMPLATE=

# Mihomo release tag used during image build.
MIHOMO_VERSION=v1.19.24

# Auto subscription update interval in seconds.
SUBSCRIPTION_UPDATE_INTERVAL=0

# ---- Offline VPS deployment settings ----
# SSH target
VPS_DEPLOY_SSH_HOST=
VPS_DEPLOY_SSH_PORT=22
VPS_DEPLOY_SSH_USER=
VPS_DEPLOY_SSH_KEY=

# Upload staging directory on remote host
VPS_DEPLOY_REMOTE_DIR=~/mihomo-aio-upload/

# Final deploy directory on remote host
VPS_DEPLOY_DEPLOY_DIR=/opt/mihomo-aio

# Container engine for local scripts and remote bootstrap runtime branch: docker or podman
# Bootstrap precheck uses dual-ensure(single-run): by default both Docker and Podman are checked/ensured.
VPS_DEPLOY_CONTAINER_ENGINE=docker

# Set 1 to skip docker ensure during remote bootstrap
MIHOMO_SKIP_DOCKER_ENSURE=0

# Set 1 to skip podman ensure during remote bootstrap
MIHOMO_SKIP_PODMAN_ENSURE=0

# Docker CE apt mirror strategy for bootstrap: auto|official|ustc|aliyun
DOCKER_CE_APT_MIRROR=auto
