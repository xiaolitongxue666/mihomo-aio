# Local environment and secrets
.env
.env.*
!.env.example
.env.local
.env.*.local

# Local OS/editor noise
.DS_Store
*.swp
*.swo

# Runtime-generated dashboard config (contains values derived from .env)
dashboard/runtime-config.json

# Common secret material and local key files
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Runtime data volumes
data/config/*
!data/config/.gitkeep

data/mihomo/*
!data/mihomo/.gitkeep

# Offline build artifacts
dist/
# Editor / sed backup files (may contain copied secrets)
*.bak

